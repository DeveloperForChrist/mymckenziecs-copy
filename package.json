{
  "name": "mymckenzie-nextjs2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:py": "python3 scripts/case-law/milvus_bridge.py",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src instrumentation.ts instrumentation-client.ts sentry.server.config.ts sentry.edge.config.ts --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "launch:check": "node scripts/ops/launch-readiness.mjs",
    "load:test": "node scripts/ops/load-test.mjs",
    "load:test:chat": "node scripts/ops/load-test.mjs --target chat --seconds 60 --concurrency 40",
    "load:test:mixed": "node scripts/ops/load-test.mjs --target mixed --seconds 60 --concurrency 40",
    "auth:cookie": "node scripts/ops/session-cookie-from-tokens.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "stripe:sync-passes": "node scripts/seed-stripe-passes.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@langchain/core": "^1.1.0",
    "@sentry/nextjs": "^10.32.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.36.1",
    "@vitejs/plugin-react": "^5.1.2",
    "dotenv": "^17.2.3",
    "jsdom": "^27.4.0",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.11.0",
    "next": "^16.1.6",
    "nodemailer": "^8.0.1",
    "openai": "^6.7.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.1",
    "stripe": "^19.3.1",
    "vitest": "^4.0.16",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.0",
    "supabase": "^2.76.6",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}

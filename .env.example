# Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@mymckenziecs.com
RESEND_ALERT_FROM_EMAIL=alerts@mymckenziecs.com
RESEND_FROM_NAME=MymckenzieCS
RESEND_ALERT_FROM_NAME=MymckenzieCS
FROM_EMAIL=noreply@mymckenziecs.com
SUPPORT_EMAIL=support@mymckenziecs.com

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
NEXT_PUBLIC_STRIPE_ESSENTIAL_PRICE_ID=your_essential_price_id
NEXT_PUBLIC_STRIPE_PREMIUM_CHEAP_PRICE_ID=your_premium_cheap_price_id
NEXT_PUBLIC_STRIPE_PLUS_PRICE_ID=your_plus_price_id
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Cron authentication for protected scheduled routes
CRON_SECRET=your_cron_secret

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o

# Groq (freemium chatbot path)
GROQ_API_KEY=your_groq_api_key
GROQ_CHAT_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_CHAT_FALLBACK_MODEL=llama-3.3-70b-versatile

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-opus-4-5-20251101

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint

# Google Generative AI
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=your_pinecone_index_name

# Database (Neon)
DATABASE_URL=your_database_url

# App URL
NEXT_PUBLIC_APP_URL=https://www.mymckenziecs.com

# Sentry Error Monitoring (Optional)
# Sign up at https://sentry.io
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Better Stack Error Logging (Optional alternative)
# Sign up at https://betterstack.com
BETTER_STACK_SOURCE_TOKEN=your_better_stack_source_token
# Optional override, defaults to https://in.logs.betterstack.com
BETTER_STACK_INGEST_URL=https://in.logs.betterstack.com

# Upstash Redis (Optional - for rate limiting)
# Sign up at https://upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
